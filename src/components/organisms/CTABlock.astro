---
/**
 * CTABlock — bloc d'appel à l'action principal sur la page d'accueil.
 *
 * Source : spec annexe A section 1 (CTA 1 "Trouver", CTA 2 "Analyser").
 *
 * Structure :
 *   - Image illustration (responsive desktop/mobile)
 *   - Titre (h2)
 *   - Description courte
 *   - Indicateur de durée (~3 minutes)
 *   - Bouton primaire pleine largeur
 *
 * L'image n'est pas above-the-fold sur mobile (vient après le hero) → `lazy`
 * est ok. Sur desktop, la grille met les deux CTAs côte à côte juste sous le
 * hero, donc on les passe en `eager` pour éviter un flash de chargement.
 *
 * Le composant est en .astro car le contenu est statique. Le bouton CTA est
 * un simple `<a>` (pas besoin d'hydrater un composant Vue pour ça).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from '../atoms/Icon.vue';

export interface Props {
  /** Titre du CTA (h2). */
  title: string;
  /** Description courte sous le titre. */
  description: string;
  /** Indicateur de temps (ex : "~3 minutes"). */
  duration: string;
  /** Texte du bouton CTA (ex : "Commencer"). */
  buttonLabel: string;
  /** URL de destination du bouton. */
  href: string;
  /** Image desktop (1448x1086, ~4:3). */
  imageDesktop: ImageMetadata;
  /** Image mobile (1254x1254, carré 1:1). */
  imageMobile: ImageMetadata;
  /** Alt text de l'image (descriptif). */
  imageAlt: string;
}

const {
  title,
  description,
  duration,
  buttonLabel,
  href,
  imageDesktop,
  imageMobile,
  imageAlt,
} = Astro.props;
---

<article
  class="group flex flex-col bg-white rounded-2xl overflow-hidden
         border border-gray-200
         shadow-sm hover:shadow-lg
         transition-shadow duration-200"
>
  <!-- Image (responsive via <picture>) -->
  <a
    href={href}
    class="block aspect-[4/3] md:aspect-[4/3] overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500"
    tabindex="-1"
    aria-hidden="true"
  >
    <picture>
      <source
        media="(max-width: 767px)"
        srcset={imageMobile.src}
        width={imageMobile.width}
        height={imageMobile.height}
      />
      <Image
        src={imageDesktop}
        alt={imageAlt}
        loading="eager"
        decoding="async"
        widths={[400, 600, 800, 1024]}
        sizes="(max-width: 767px) 100vw, 50vw"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </picture>
  </a>

  <!-- Contenu -->
  <div class="flex flex-col flex-grow p-6 gap-3">
    <h3
      class="text-2xl font-semibold text-gray-900"
      style="font-family: var(--font-display, serif);"
    >
      {title}
    </h3>

    <p class="text-base text-gray-700 flex-grow">
      {description}
    </p>

    <p class="text-sm flex items-center gap-1.5" style="color: var(--color-muted, #6b7280)">
      <Icon name="loader" :size="14" aria-hidden="true" />
      {duration}
    </p>

    <a
      href={href}
      class="mt-2 inline-flex items-center justify-center gap-2
             bg-teal-700 hover:bg-teal-800 text-white
             font-medium rounded-lg
             px-5 py-3 min-h-[44px] w-full
             transition-colors
             focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-teal-500"
    >
      <span>{buttonLabel}</span>
      <Icon name="arrow-right" :size="16" aria-hidden="true" />
    </a>
  </div>
</article>
