---
/**
 * HeroSection — section hero pleine largeur avec image background + overlay.
 *
 * Source : spec annexe A section 1.2 (mobile 380px) + 1.3 (desktop 520px).
 *
 * Comportement responsive :
 *   - Mobile (<md, 768px) : image portrait (1122x1402, 4:5) en background
 *   - Desktop (md+)       : image paysage (1672x941, 16:9) en background
 *
 * Le swap d'image se fait via `<picture>` avec `<source media>` pour servir
 * uniquement l'image pertinente selon le viewport (économise la bande passante
 * mobile et améliore LCP).
 *
 * Le composant est passé en `priority` (équivalent `loading="eager"`) parce
 * qu'il est above-the-fold sur toutes les tailles d'écran (cf. spec 1.7 :
 * LCP < 2.0s en 4G simulé).
 */
import { Image } from 'astro:assets';
import heroDesktop from '../../assets/illustrations/home/home-hero.webp';
import heroMobile from '../../assets/illustrations/home/home-hero-mobile.webp';

export interface Props {
  /** Titre H1 (visible, principal SEO). */
  title: string;
  /** Sous-titre court explicatif. */
  subtitle: string;
  /** Alt text de l'image background (descriptif, pour a11y et SEO image). */
  imageAlt: string;
}

const { title, subtitle, imageAlt } = Astro.props;
---

<section
  class="relative w-full overflow-hidden bg-teal-900"
  aria-labelledby="hero-title"
>
  <!--
    Image background : <picture> avec source mobile (portrait) + desktop (paysage).
    `loading="eager"` + `fetchpriority="high"` pour LCP optimal.
  -->
  <picture class="absolute inset-0 -z-0">
    <source
      media="(max-width: 767px)"
      srcset={heroMobile.src}
      width={heroMobile.width}
      height={heroMobile.height}
    />
    <Image
      src={heroDesktop}
      alt={imageAlt}
      loading="eager"
      decoding="sync"
      class="w-full h-full object-cover object-center"
      widths={[768, 1024, 1440, 1920]}
      sizes="100vw"
    />
  </picture>

  <!-- Overlay teal sombre pour lisibilité du texte par-dessus -->
  <div
    class="absolute inset-0 z-10 bg-gradient-to-b from-teal-900/70 via-teal-900/50 to-teal-900/80"
    aria-hidden="true"
  ></div>

  <!-- Contenu texte centré -->
  <div class="relative z-20 max-w-5xl mx-auto px-4 sm:px-8 py-20 md:py-32 text-center">
    <h1
      id="hero-title"
      class="text-3xl sm:text-5xl md:text-6xl font-semibold text-white leading-tight mb-4"
      style="font-family: var(--font-display, serif);"
    >
      {title}
    </h1>
    <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto">
      {subtitle}
    </p>
  </div>
</section>
