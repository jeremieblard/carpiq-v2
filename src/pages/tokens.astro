---
import BaseLayout from '../components/layouts/BaseLayout.astro';
---
<BaseLayout title="Design Tokens — CarPIQ V2">
  <main class="max-w-6xl mx-auto p-8">
    <h1 class="text-5xl mb-2">Design Tokens CarPIQ V2</h1>
    <p class="text-[color:var(--color-muted)] mb-12">Référence visuelle des tokens définis dans <code>global.css</code></p>
    
    <!-- COULEURS PRIMAIRES -->
    <section class="mb-16">
      <h2 class="text-3xl mb-6 text-teal-500">Couleurs primaires</h2>
      
      <h3 class="text-xl font-bold mb-3">Teal (primaire)</h3>
      <div class="grid grid-cols-5 md:grid-cols-10 gap-2 mb-8">
        <div class="bg-teal-50 p-3 text-xs">50</div>
        <div class="bg-teal-100 p-3 text-xs">100</div>
        <div class="bg-teal-200 p-3 text-xs">200</div>
        <div class="bg-teal-300 p-3 text-xs text-white">300</div>
        <div class="bg-teal-400 p-3 text-xs text-white">400</div>
        <div class="bg-teal-500 p-3 text-xs text-white">500</div>
        <div class="bg-teal-600 p-3 text-xs text-white">600</div>
        <div class="bg-teal-700 p-3 text-xs text-white">700</div>
        <div class="bg-teal-800 p-3 text-xs text-white">800</div>
        <div class="bg-teal-900 p-3 text-xs text-white">900</div>
      </div>
      
      <h3 class="text-xl font-bold mb-3">Amber (accent)</h3>
      <div class="grid grid-cols-5 md:grid-cols-10 gap-2">
        <div class="bg-amber-50 p-3 text-xs">50</div>
        <div class="bg-amber-100 p-3 text-xs">100</div>
        <div class="bg-amber-200 p-3 text-xs">200</div>
        <div class="bg-amber-300 p-3 text-xs">300</div>
        <div class="bg-amber-400 p-3 text-xs text-white">400</div>
        <div class="bg-amber-500 p-3 text-xs text-white">500</div>
        <div class="bg-amber-600 p-3 text-xs text-white">600</div>
        <div class="bg-amber-700 p-3 text-xs text-white">700</div>
        <div class="bg-amber-800 p-3 text-xs text-white">800</div>
        <div class="bg-amber-900 p-3 text-xs text-white">900</div>
      </div>
    </section>
    
    <!-- COULEURS SÉMANTIQUES -->
    <section class="mb-16">
      <h2 class="text-3xl mb-6 text-teal-500">Couleurs sémantiques</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-6 rounded-lg border border-[color:var(--color-border)]" style="background: var(--color-bg)">
          <div class="font-bold">bg</div>
          <div class="text-sm text-[color:var(--color-muted)]">#FAFAF9</div>
        </div>
        <div class="p-6 rounded-lg bg-white border border-[color:var(--color-border)]">
          <div class="font-bold">card</div>
          <div class="text-sm text-[color:var(--color-muted)]">#FFFFFF</div>
        </div>
        <div class="p-6 rounded-lg" style="background: var(--color-ink); color: white">
          <div class="font-bold">ink</div>
          <div class="text-sm">#1A1A1A</div>
        </div>
        <div class="p-6 rounded-lg" style="background: var(--color-muted); color: white">
          <div class="font-bold">muted</div>
          <div class="text-sm">#6B7280</div>
        </div>
      </div>
    </section>
    
    <!-- TYPOGRAPHIE -->
    <section class="mb-16">
      <h2 class="text-3xl mb-6 text-teal-500">Typographie</h2>
      
      <div class="mb-8">
        <h3 class="text-xl font-bold mb-3">Display (Playfair Display)</h3>
        <p class="text-6xl">CarPIQ</p>
        <p class="text-5xl">Comparateur</p>
        <p class="text-4xl">Comparateur automobile</p>
        <p class="text-3xl">Quelle voiture acheter ?</p>
        <p class="text-2xl">Quelle voiture acheter ?</p>
      </div>
      
      <div style="font-family: var(--font-body)">
        <h3 class="text-xl font-bold mb-3">Body (DM Sans)</h3>
        <p class="text-lg">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        <p class="text-base">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        <p class="text-sm">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        <p class="text-xs">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
    </section>
    
    <!-- BOUTONS PROTOTYPES -->
    <section class="mb-16">
      <h2 class="text-3xl mb-6 text-teal-500">Boutons (prototypes — refonte Phase 2)</h2>
      <div class="flex flex-wrap gap-4">
        <button class="bg-teal-500 hover:bg-teal-600 text-white px-6 py-3 rounded-lg transition-colors">
          Primaire teal
        </button>
        <button class="bg-amber-500 hover:bg-amber-600 text-white px-6 py-3 rounded-lg transition-colors">
          Accent amber
        </button>
        <button class="border border-teal-500 text-teal-500 hover:bg-teal-50 px-6 py-3 rounded-lg transition-colors">
          Secondaire
        </button>
        <button class="text-teal-500 hover:underline px-6 py-3">
          Lien tertiaire
        </button>
      </div>
    </section>
    
    <p class="text-center text-sm mt-16" style="color: var(--color-muted)">
      CarPIQ V2 — Design tokens · 
      <a href="/" class="text-teal-500 hover:underline">Retour à l'accueil</a>
    </p>
  </main>
</BaseLayout>
