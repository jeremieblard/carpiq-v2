---
/**
 * Racine du site — redirige vers la langue par défaut.
 *
 * Astro 4+ i18n routing.redirectToDefaultLocale = true gère normalement
 * cette redirection automatiquement quand prefixDefaultLocale = true.
 * Cette page existe en filet de sécurité (build statique sans middleware).
 */
import { DEFAULT_LANG } from '../i18n';
return Astro.redirect(`/${DEFAULT_LANG}/`);
---
